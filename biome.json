{
	"files": {
		"ignore": [
			".claude/**",
			".beads/**",
			"data/**",
			"package.json",
			"tsconfig.json",
			"sample-eval-app/**",
			"eval/results/**"
		]
	},
	"formatter": {
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"overrides": [
		{
			"include": ["src/projects/**"],
			"linter": {
				"enabled": false
			},
			"formatter": {
				"enabled": false
			}
		}
	]
}
