{
	"name": "shipsummit-fullstack-app",
	"version": "1.0.0",
	"description": "Ship Summit Fullstack App - TypeScript + PostgreSQL + Frontend",
	"type": "module",
	"scripts": {
		"dev": "bun run --watch --env-file .env src/index.ts",
		"start": "bun run src/index.ts",
		"build": "bun build src/index.ts --outdir ./dist --target node",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/ --max-warnings 0",
		"lint:fix": "eslint src/ --fix --max-warnings 0",
		"lint:biome": "bun x --bun @biomejs/biome@1.9.4 lint . --error-on-warnings && bun x --bun @biomejs/biome@1.9.4 format .",
		"circular": "madge --circular --extensions ts src/index.ts",
		"test": "bun test",
		"check:lint": "bun run lint:biome && bun run lint && bun run typecheck && bun run circular",
		"check": "bun run check:lint && bun run test && echo '✅ All checks passed!'",
		"eval": "bun run scripts/run-eval.ts",
		"prepare": "git config core.hooksPath .githooks",
		"db:migrate": "bun run --env-file .env src/components/db/migrate.ts",
		"db:seed": "bun run --env-file .env src/components/db/seed.ts",
		"db:studio": "bunx drizzle-kit studio --config=drizzle.config.ts"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.82.0",
		"@sparticuz/chromium": "^143.0.4",
		"beads": "^0.2.1",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.4.0",
		"postgres": "^3.4.4",
		"puppeteer-core": "^24.40.0"
	},
	"devDependencies": {
		"@types/bun": "^1.1.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.0.0",
		"eslint-plugin-sonarjs": "^3.0.0",
		"eslint-plugin-unused-imports": "^4.0.0",
		"madge": "^8.0.0",
		"playwright": "^1.59.0",
		"typescript": "^5.4.0",
		"typescript-eslint": "^8.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"shipsummit",
		"fullstack",
		"typescript",
		"postgresql",
		"hono",
		"bun"
	],
	"author": "Ship Summit Team",
	"license": "MIT"
}
