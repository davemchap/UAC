# =============================================================================
# Ship Summit Fullstack App - Environment Variables
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# In production, these variables are automatically set by the CI/CD pipeline.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONNECTION
# -----------------------------------------------------------------------------
# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
#
# For local development with Docker:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp
#
# In production, this is automatically injected by the CI/CD pipeline
DATABASE_URL=postgresql://aiAssistant@localhost:5432/shipsummit_dev

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Port the server listens on (default: 3000)
PORT=3000

# Environment mode (development or production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# OPTIONAL: ADD YOUR OWN VARIABLES BELOW
# -----------------------------------------------------------------------------
# Examples:
# API_KEY=your-api-key
# JWT_SECRET=your-jwt-secret
# REDIS_URL=redis://localhost:6379
